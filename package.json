{
  "name": "gouraan-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "GoUraan Monorepo",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "npm run --workspace=@gouraan/backend start:dev",
    "start:frontend": "npm run --workspace=@gouraan/frontend dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "npm run --workspace=@gouraan/backend build",
    "build:frontend": "npm run --workspace=@gouraan/frontend build",
    "test": "echo \"Error: no test specified\" && exit 1",
    "postinstall": "(cd packages/backend && npm run prisma:generate)",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "npm run --workspace=@gouraan/backend lint",
    "lint:frontend": "npm run --workspace=@gouraan/frontend lint",
    "db:migrate": "npm run --workspace=@gouraan/backend prisma:migrate",
    "db:studio": "npm run --workspace=@gouraan/backend prisma:studio",
    "db:generate": "npm run --workspace=@gouraan/backend prisma:generate",
    "db:reset": "npm run --workspace=@gouraan/backend prisma:reset",
    "prisma:generate": "npm run --workspace=@gouraan/backend prisma:generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@tanstack/react-query": "^5.17.19",
    "axios": "^1.6.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.1",
    "framer-motion": "^11.0.3",
    "lucide-react": "^0.309.0",
    "next": "14.0.4",
    "next-auth": "^4.24.5",
    "next-intl": "^3.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.3",
    "recharts": "^2.10.4",
    "tailwind-merge": "^2.2.0",
    "zod": "^3.22.4",
    "concurrently": "^8.2.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.10",
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.42",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.56.0",
    "eslint-config-next": "14.0.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.1.1",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.1.1",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.17",
    "@types/supertest": "^2.0.12",
    "prisma": "5.6.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.1.3",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.2"
  },
  "overrides": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.2"
  },
  "packageManager": "npm@10.2.4"
}
