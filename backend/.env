# Application
NODE_ENV=development
PORT=3001
APP_NAME=GoUraan API
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Database (using Docker container)
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/gouraan

# Redis (using Docker container)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=dev-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# Encryption
ENCRYPTION_KEY=dev-32-char-encryption-key-12

# Email (Development - use mailtrap or similar)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@gouraan.com
FROM_NAME=GoUraan

# Payment Gateways (Test mode)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

PAYPAL_CLIENT_ID=placeholder
PAYPAL_CLIENT_SECRET=placeholder
PAYPAL_MODE=sandbox

SSLCOMMERZ_STORE_ID=placeholder
SSLCOMMERZ_STORE_PASSWORD=placeholder
SSLCOMMERZ_IS_LIVE=false

HYPERPAY_USER_ID=placeholder
HYPERPAY_PASSWORD=placeholder
HYPERPAY_ENTITY_ID=placeholder
HYPERPAY_IS_LIVE=false

# External APIs
AMADEUS_API_KEY=placeholder
AMADEUS_API_SECRET=placeholder
AMADEUS_BASE_URL=https://test.api.amadeus.com

GOOGLE_MAPS_API_KEY=placeholder

# File Storage
AWS_ACCESS_KEY_ID=placeholder
AWS_SECRET_ACCESS_KEY=placeholder
AWS_REGION=us-east-1
AWS_S3_BUCKET=gouraan-files-dev

CLOUDINARY_CLOUD_NAME=placeholder
CLOUDINARY_API_KEY=placeholder
CLOUDINARY_API_SECRET=placeholder

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# Queue/Jobs
BULL_REDIS_HOST=localhost
BULL_REDIS_PORT=6379
BULL_REDIS_PASSWORD=

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_EMAIL_VERIFICATION=false
ENABLE_SMS_VERIFICATION=false
ENABLE_TWO_FACTOR_AUTH=false
ENABLE_LOYALTY_PROGRAM=true
ENABLE_AFFILIATE_SYSTEM=true
