# App Configuration
NEXT_PUBLIC_APP_NAME=GoUraan
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# Authentication
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here

# Database (if needed for NextAuth)
DATABASE_URL=postgresql://username:password@localhost:5432/gouraan

# External APIs
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
NEXT_PUBLIC_AMADEUS_API_KEY=your-amadeus-api-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# Payment Gateways
NEXT_PUBLIC_SSLCOMMERZ_STORE_ID=your-sslcommerz-store-id
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=your-google-analytics-id

# Feature Flags
NEXT_PUBLIC_ENABLE_HAJJ_BOOKING=true
NEXT_PUBLIC_ENABLE_MULTI_CURRENCY=true
NEXT_PUBLIC_ENABLE_LOYALTY_PROGRAM=true

# Environment
NODE_ENV=development
